{
  "expo": {
    "name": "Mission Control",
    "slug": "mission-control-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "mission-control",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1F2937"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.openclaw.missioncontrol"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1F2937",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.openclaw.missioncontrol"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
